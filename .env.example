# Copy to .env and fill in your key. The real .env is gitignored.
#
# Munney's import analyst is a MANDATORY AI agent: every CSV or Markdown file
# you import is read and analyzed by DeepSeek, which finds and creates the
# transactions itself — no fixed column schema required.
#
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional overrides (defaults shown):
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
